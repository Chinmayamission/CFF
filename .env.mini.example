# CFF Mini Environment Variables
# Copy this file to .env.mini and fill in the values

# =============================================================================
# AWS Cognito (Required for authentication)
# =============================================================================
# Get these from your AWS Cognito User Pool
USER_POOL_ID=us-east-1_kcpcLxLzn
COGNITO_CLIENT_ID=77mcm1k9ll2ge68806h5kncfus

# =============================================================================
# MongoDB (Required)
# =============================================================================
# For local development with docker-compose, use:
# MONGO_CONN_STR=mongodb://mongodb:27017/cff_dev
#
# For Railway or production, use MongoDB Atlas connection string:
# MONGO_CONN_STR=mongodb+srv://user:password@cluster.mongodb.net/cff_prod
MONGO_CONN_STR=
DB_NAME=

# =============================================================================
# Optional
# =============================================================================
# Google Maps API Key (for address autocomplete features)
GOOGLE_MAPS_API_KEY=

# AWS SES Configuration (for sending emails)
SES_AWS_ACCESS_KEY_ID=
SES_AWS_SECRET_ACCESS_KEY=
SES_AWS_REGION=us-east-1

# Application mode (DEV, BETA, or PROD)
MODE=PROD
